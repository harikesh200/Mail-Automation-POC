    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.80",
        "@llamaindex/liteparse": "^2.0.7",
        "ai": "^6.0.198",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "googleapis": "^173.0.0",
        "mailparser": "^3.9.9",
        "mammoth": "^1.12.0",
        "pino": "^10.3.1",
        "xlsx": "^0.18.5",
        "zod": "^4.4.3"
